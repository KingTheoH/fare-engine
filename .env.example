# ============================================================
# Fare Construction Engine — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ============================================================

# Database
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://fare_engine:change_me_in_production@localhost:5432/fare_engine
TEST_DATABASE_URL=postgresql+asyncpg://fare_engine:change_me_in_production@localhost:5432/fare_engine_test

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM (Phase 06 — community ingestion)
CLAUDE_API_KEY=sk-ant-...

# ITA Matrix Automation (Phase 04)
# Comma-separated list of proxy connection strings: user:pass@host:port
ITA_PROXY_LIST=user1:pass1@proxy1.example.com:8080,user2:pass2@proxy2.example.com:8080
ITA_RATE_LIMIT_SECONDS=3.5
ITA_JITTER_MAX_SECONDS=2.0
HEADLESS=true   # Set to false for debugging automation

# API Auth (Phase 09)
# Initial API key for development. Use a proper secrets manager in production.
INITIAL_API_KEY=dev_key_change_in_production

# Alerts (Phase 08)
# Comma-separated webhook URLs (Slack, Discord, custom)
ALERT_WEBHOOK_URLS=
ALERT_MIN_SEVERITY=MEDIUM   # INFO, MEDIUM, or HIGH

# Frontend (Phase 10)
BACKEND_URL=http://backend:8000
NEXT_PUBLIC_API_KEY=dev_key_change_in_production

# App
LOG_LEVEL=INFO
ENVIRONMENT=development   # development, staging, production
